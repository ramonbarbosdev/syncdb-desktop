{
  "name": "syncdb-desktop",
  "version": "1.0.79",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac --arm64",
    "build:linux": "electron-builder --linux",
    "prepare:release": "node scripts/prepare-release.js",
    "release:win": "npm run prepare:release && electron-builder --win",
    "release:linux": "npm run prepare:release && electron-builder --linux",
    "release:mac": "npm run prepare:release && electron-builder --mac",
    "release:patch:win": "npm run version:patch && npm run release:win",
    "release:minor:win": "npm run version:minor && npm run release:win",
    "release:major:win": "npm run version:major && npm run release:win",
    "release:patch:linux": "npm run version:patch && npm run release:linux",
    "release:minor:linux": "npm run version:minor && npm run release:linux",
    "release:major:linux": "npm run version:major && npm run release:linux",
    "release:patch:mac": "npm run version:patch && npm run release:mac",
    "release:minor:mac": "npm run version:minor && npm run release:mac",
    "release:major:mac": "npm run version:major && npm run release:mac",
    "release:publish": "node scripts/release.js"
  },
  "author": "Ramon Barbosa",
  "description": "Aplicativo de sincronização de banco de dados desktop",
  "license": "MIT",
  "homepage": "https://github.com/ramonbarbosdev/syncdb-desktop",
  "devDependencies": {
    "dotenv": "^16.5.0",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "electron-log": "^5.4.1",
    "electron-updater": "^6.6.2",
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "com.suaempresa.syncdb",
    "productName": "SyncDB Desktop",
    "publish": [
      {
        "provider": "github",
        "owner": "ramonbarbosdev",
        "repo": "syncdb-desktop",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ],
    "files": [
      "package.json",
      "main.js",
      "updater.js",
      "window.js",
      "back-end.js",
      "preload.js",
      "dist/browser/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/syncdb.jar",
        "to": "backend/syncdb.jar"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon",
      "extraResources": [
        {
          "from": "backend/jre",
          "to": "backend/jre"
        }
      ]
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "backend/jre",
          "to": "backend/jre"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "backend/jre",
          "to": "backend/jre"
        }
      ]
    }
  }
}
